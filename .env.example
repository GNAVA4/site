# Шаблон переменных окружения. Скопируйте в .env (для прода) и заполните.
# .env в репозиторий НЕ коммитится (см. .gitignore). settings.py читает их через os.environ.
# Для ЛОКАЛЬНОЙ разработки .env не обязателен: есть безопасные дефолты (DEBUG=True,
# Postgres из docker-compose на 127.0.0.1:5433, письма в консоль).

# --- Django ---
DJANGO_SECRET_KEY=замените-на-длинную-случайную-строку
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=example.com,www.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
DJANGO_SECURE_SSL_REDIRECT=True

# --- База данных (PostgreSQL) ---
# Формат: postgres://USER:PASSWORD@HOST:PORT/DBNAME
# Локально (Docker, docker-compose.yml): postgres://shop:shop@127.0.0.1:5433/shop
DATABASE_URL=postgres://user:password@localhost:5432/dbname
DJANGO_CONN_MAX_AGE=60

# --- Email (SMTP; на проде, при DEBUG=False) ---
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=shop@example.com
